# Minimal workshop demo pipeline:
# 1. Python centres the values in example_data.csv  → work/1_derived.csv
# 2. R reads 1_derived.csv and produces summary stats → work/2_summary.txt
# 3. Python (polars) processes the derived data       → work/3_processed.csv
# 4. Quarto collects outputs into an HTML report      → results/4_report.html
#
# Run with:  snakemake --cores 1
# Run from any directory with:
#   snakemake --snakefile /path/to/Snakefile --cores 1

# Absolute path to this Snakefile's directory — keeps all paths stable
# regardless of where snakemake is invoked from.
D = workflow.basedir

rule all:
    input:
        f"{D}/results/4_report.html"


rule py_derive:
    input:
        data=f"{D}/example_data.csv",
        script=f"{D}/1_derive.py",
    output:
        f"{D}/work/1_derived.csv",
    shell:
        "python3 {input.script} --input {input.data} --output {output}"


rule r_summary:
    input:
        data=f"{D}/work/1_derived.csv",
        script=f"{D}/2_summary.R",
    output:
        f"{D}/work/2_summary.txt",
    shell:
        "Rscript {input.script} --input {input.data} --output {output}"


rule polars_process:
    input:
        data=f"{D}/work/1_derived.csv",
        summary=f"{D}/work/2_summary.txt",
        script=f"{D}/3_polars_process.py",
    output:
        f"{D}/work/3_processed.csv",
    shell:
        "python3 {input.script} --input {input.data} --summary {input.summary} --output {output}"


rule final_report:
    input:
        qmd=f"{D}/4_report.qmd",
        data=f"{D}/example_data.csv",
        derived=f"{D}/work/1_derived.csv",
        summary=f"{D}/work/2_summary.txt",
        processed=f"{D}/work/3_processed.csv",
    output:
        f"{D}/results/4_report.html",
    params:
        basedir=D,
    shell:
        "cd {params.basedir} && quarto render 4_report.qmd --to html && mkdir -p results && mv 4_report.html results/"
